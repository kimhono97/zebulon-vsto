<Window x:Class="ZebulonVSTO.Slides.WordSelectWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ZebulonVSTO.Slides"
    mc:Ignorable="d"
    FontFamily="Malgun Gothic" FontSize="13"
    Height="680" Width="740" MinHeight="580" MinWidth="660"
    Title="구절 추가" ShowInTaskbar="False" WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <!-- Verse tap-row: number + preview text + start/end marker. The row
             background / border reflect VerseRow.Role (single/start/end/middle),
             mirroring the web SectionPicker's range-style rendering. -->
        <Style x:Key="VerseRowStyle" TargetType="Button">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#FFE6E6E6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Role}" Value="single">
                    <Setter Property="Background" Value="#FFCDE8FF"/>
                    <Setter Property="BorderBrush" Value="#FF5BA4E6"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Role}" Value="start">
                    <Setter Property="Background" Value="#FFCDE8FF"/>
                    <Setter Property="BorderBrush" Value="#FF5BA4E6"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Role}" Value="end">
                    <Setter Property="Background" Value="#FFCDE8FF"/>
                    <Setter Property="BorderBrush" Value="#FF5BA4E6"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Role}" Value="middle">
                    <Setter Property="Background" Value="#FFEAF4FF"/>
                    <Setter Property="BorderBrush" Value="#FFBFD9F2"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <DataTemplate x:Key="VerseRowTemplate">
            <Button Style="{StaticResource VerseRowStyle}" Click="Verse_Click">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Left" Width="34" Margin="0,0,8,0"
                               Text="{Binding Number}" FontWeight="Bold"
                               Foreground="#FF5A5A5A" HorizontalAlignment="Right"/>
                    <TextBlock DockPanel.Dock="Right" Text="{Binding Marker}"
                               Foreground="#FF2C7BD0" FontSize="11" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                </DockPanel>
            </Button>
        </DataTemplate>
        <!-- Committed-range chip: "S-E" with an ✕ to remove the range. -->
        <DataTemplate x:Key="SegmentChipTemplate">
            <Border Background="#FFEDF4FB" BorderBrush="#FF9CC6EC" BorderThickness="1"
                    CornerRadius="10" Padding="8,1" Margin="0,0,6,4">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
                    <Button Content="✕" Margin="6,0,0,0" Padding="2,0" FontSize="11"
                            BorderThickness="0" Background="Transparent" Cursor="Hand"
                            Click="RemoveChip_Click"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Version / language / ruby slots -->
        <StackPanel Grid.Row="0">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="언어 수" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="LangCountCombo" Width="60" SelectionChanged="LangCountCombo_SelectionChanged"/>
            </StackPanel>
            <StackPanel x:Name="Slot0" Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="언어 1" Width="52" VerticalAlignment="Center"/>
                <ComboBox x:Name="Lang0" Width="110" DisplayMemberPath="Name" SelectionChanged="Lang_SelectionChanged"/>
                <ComboBox x:Name="Ver0" Width="170" Margin="6,0,0,0" DisplayMemberPath="Name" SelectionChanged="Ver_SelectionChanged"/>
                <ComboBox x:Name="Ruby0" Width="130" Margin="6,0,0,0" IsEnabled="False" SelectionChanged="Ruby_SelectionChanged"/>
            </StackPanel>
            <StackPanel x:Name="Slot1" Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="언어 2" Width="52" VerticalAlignment="Center"/>
                <ComboBox x:Name="Lang1" Width="110" DisplayMemberPath="Name" SelectionChanged="Lang_SelectionChanged"/>
                <ComboBox x:Name="Ver1" Width="170" Margin="6,0,0,0" DisplayMemberPath="Name" SelectionChanged="Ver_SelectionChanged"/>
                <ComboBox x:Name="Ruby1" Width="130" Margin="6,0,0,0" IsEnabled="False" SelectionChanged="Ruby_SelectionChanged"/>
            </StackPanel>
            <StackPanel x:Name="Slot2" Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="언어 3" Width="52" VerticalAlignment="Center"/>
                <ComboBox x:Name="Lang2" Width="110" DisplayMemberPath="Name" SelectionChanged="Lang_SelectionChanged"/>
                <ComboBox x:Name="Ver2" Width="170" Margin="6,0,0,0" DisplayMemberPath="Name" SelectionChanged="Ver_SelectionChanged"/>
                <ComboBox x:Name="Ruby2" Width="130" Margin="6,0,0,0" IsEnabled="False" SelectionChanged="Ruby_SelectionChanged"/>
            </StackPanel>
            <Separator Margin="0,8,0,8"/>
        </StackPanel>

        <!-- Book (left) / chapter + verse picker (right) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0" Margin="0,0,12,0">
                <TextBlock DockPanel.Dock="Top" Text="책" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBox DockPanel.Dock="Top" x:Name="BookFilter" Margin="0,0,0,6" TextChanged="BookFilter_TextChanged"/>
                <ListBox x:Name="BookList" SelectionChanged="BookList_SelectionChanged"/>
            </DockPanel>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Chapter + verse count -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="장" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="ChapterCombo" Width="90" SelectionChanged="ChapterCombo_SelectionChanged"/>
                    <TextBlock x:Name="VerseCountText" VerticalAlignment="Center" Margin="14,0,0,0" Foreground="#FF777777"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="절 범위 (절을 눌러 시작–끝 선택)" FontWeight="Bold" Margin="0,0,0,4"/>

                <!-- Committed chips + pending range + hint -->
                <StackPanel Grid.Row="2" Margin="0,0,0,6">
                    <ItemsControl x:Name="SegmentChips" ItemTemplate="{StaticResource SegmentChipTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                    <StackPanel x:Name="PendingPanel" Orientation="Horizontal" Visibility="Collapsed">
                        <Border Background="#FFFFF3C4" BorderBrush="#FFE6C200" BorderThickness="1"
                                CornerRadius="10" Padding="8,1" VerticalAlignment="Center">
                            <TextBlock x:Name="PendingLabel"/>
                        </Border>
                        <Button x:Name="CommitButton" Content="＋ 범위 추가" Margin="8,0,0,0"
                                Padding="8,2" Click="CommitPending_Click"/>
                    </StackPanel>
                    <TextBlock x:Name="SelectHint" Foreground="#FF999999"
                               Text="절을 눌러 범위를 선택하세요."/>
                </StackPanel>

                <!-- Verse tap-list -->
                <Border Grid.Row="3" BorderBrush="#FFD0D0D0" BorderThickness="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="VerseList" ItemTemplate="{StaticResource VerseRowTemplate}" Margin="4"/>
                    </ScrollViewer>
                </Border>

                <TextBlock Grid.Row="4" x:Name="WordSelectStatus" Foreground="#FF777777"
                           TextWrapping="Wrap" Margin="0,8,0,0"/>
            </Grid>
        </Grid>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="CancelButton" Content="취소" Width="80" Margin="0,0,8,0" Click="CancelButton_Click"/>
            <Button x:Name="AddButton" Content="추가" Width="100" FontWeight="Bold" Click="AddButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
