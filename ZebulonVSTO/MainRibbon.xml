<?xml version="1.0" encoding="UTF-8"?>
<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui" onLoad="Ribbon_Load">
  <ribbon>
    <tabs>
      <tab idMso="TabAddIns" label="Zebulon">
		  <group id="GroupInfo" label="정보">
			  <button id="BtnAbout" label="Zebulon 정보" size="large" imageMso="Info" onAction="OnBtnAction"/>
		  </group>
		  <group id="GroupSync" label="동기화">
			  <!-- Col 1: start/stop (large = 3 normal rows tall). Stopped → opens the
			       setup wizard; running → stops sync. -->
			  <button id="BtnSync" size="large" getImage="GetImage" getLabel="GetLabel" onAction="OnBtnAction"/>
			  <!-- Col 2: tools. Lower two rows intentionally empty (reserved for future counters). -->
			  <box id="BoxTools" boxStyle="vertical">
				  <button id="BtnConsole" size="normal" label="콘솔" imageMso="ActiveXTextBox" getEnabled="GetEnabled" onAction="OnBtnAction"/>
			  </box>
			  <!-- Col 3: status strip (3 rows). Minimal when stopped; self/peer info while running. -->
			  <box id="BoxStatus" boxStyle="vertical">
				  <labelControl id="LblState" getLabel="GetLabel"/>
				  <labelControl id="LblLocal" getLabel="GetLabel" getVisible="GetVisible"/>
				  <labelControl id="LblRemote" getLabel="GetLabel" getVisible="GetVisible"/>
			  </box>
		  </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>
