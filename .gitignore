# Visual Studio / VSTO build artifacts
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
[Bb]uild/

# NuGet packages (restored via packages.config)
packages/
*.nupkg

# Visual Studio user-specific files
*.user
*.suo
*.userosscache
*.sln.docstates
.vs/

# Visual Studio project-upgrade / migration reports (generated when opening in a newer VS)
UpgradeLog*.htm
UpgradeLog*.XML
_UpgradeReport_Files/
Backup*/
MigrationBackup/

# ReSharper / Rider
_ReSharper*/
*.DotSettings.user

# Test / coverage results
[Tt]est[Rr]esult*/
*.coverage

# OS cruft
Thumbs.db
.DS_Store

# NOTE: ZebulonVSTO_TemporaryKey.pfx is intentionally tracked as the VSTO
# manifest signing key. Keep this exception so the blanket *.pfx-style rules
# some editors add later won't drop it.
!ZebulonVSTO/ZebulonVSTO_TemporaryKey.pfx
